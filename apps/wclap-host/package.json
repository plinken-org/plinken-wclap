{
  "name": "@plinken/wclap-host",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-shelf.mjs && vite",
    "build:shelf": "node scripts/build-shelf.mjs",
    "build": "node scripts/build-shelf.mjs && tsc --noEmit && vite build",
    "preview": "wrangler dev",
    "deploy": "node scripts/build-shelf.mjs && vite build && wrangler deploy",
    "check": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wrangler": "^4.90.1"
  }
}
