{
  "name": "@plinken/site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/build-shelf.mjs && vite dev",
    "build:shelf": "node ../../scripts/build-shelf.mjs",
    "build": "node ../../scripts/build-shelf.mjs && vite build",
    "preview": "wrangler dev",
    "deploy": "node ../../scripts/build-shelf.mjs && vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wrangler": "^4.90.1"
  }
}
